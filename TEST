<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Nursing Solution Test Series</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
font-family:Arial,sans-serif;
background:#f4f7fb;
}
.header{
background:#0d6efd;
color:#fff;
padding:15px;
text-align:center;
font-size:24px;
font-weight:bold;
}
.topbar{
display:flex;
justify-content:space-between;
padding:10px 15px;
background:#fff;
box-shadow:0 2px 5px rgba(0,0,0,.1);
position:sticky;
top:0;
z-index:100;
}
.progress-wrap{
width:100%;
background:#ddd;
height:10px;
border-radius:10px;
margin-top:5px;
}
.progress{
height:10px;
width:0%;
background:#0d6efd;
border-radius:10px;
}
.container{
max-width:1200px;
margin:auto;
padding:15px;
display:flex;
gap:20px;
}
.left{
flex:3;
}
.right{
flex:1;
background:#fff;
padding:15px;
border-radius:10px;
height:fit-content;
box-shadow:0 2px 10px rgba(0,0,0,.08);
}
.card{
background:#fff;
padding:20px;
border-radius:10px;
box-shadow:0 2px 10px rgba(0,0,0,.08);
}
.question{
font-size:20px;
margin-bottom:15px;
}
.option{
display:block;
padding:10px;
margin:8px 0;
border:1px solid #ddd;
border-radius:8px;
cursor:pointer;
}
.option:hover{
background:#f2f6ff;
}
.nav-btns{
display:flex;
justify-content:space-between;
margin-top:20px;
}
button{
padding:10px 20px;
border:none;
background:#0d6efd;
color:#fff;
border-radius:6px;
cursor:pointer;
}
.palette{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:8px;
}
.palette button{
padding:10px;
}
.answered{
background:green!important;
}
.result{
display:none;
background:#fff;
padding:20px;
border-radius:10px;
box-shadow:0 2px 10px rgba(0,0,0,.08);
text-align:center;
}
.links{
margin-top:20px;
}
.links a{
display:block;
text-decoration:none;
background:#0d6efd;
color:#fff;
padding:10px;
margin:10px 0;
border-radius:6px;
}
@media(max-width:768px){
.container{
flex-direction:column;
}
}
</style>
</head>
<body>

<div class="header">NURSING SOLUTION TEST SERIES</div>

<div class="topbar">
<div>
Time Left: <span id="timer">60:00</span>
<div class="progress-wrap">
<div class="progress" id="progress"></div>
</div>
</div>
<div>
Question <span id="currentNo">1</span>/<span id="totalNo">0</span>
</div>
</div>

<div class="container">

<div class="left">

<div class="card" id="quizBox">
<div class="question" id="questionText">Loading...</div>
<div id="options"></div>

<div class="nav-btns">
<button onclick="prevQuestion()">Previous</button>
<button onclick="nextQuestion()">Next</button>
</div>

<br>
<button onclick="submitTest()">Submit Test</button>
</div>

<div class="result" id="resultBox">
<h2>Test Result</h2>
<br>
<p>Total Questions: <span id="rTotal"></span></p>
<p>Correct: <span id="rCorrect"></span></p>
<p>Wrong: <span id="rWrong"></span></p>
<p>Score: <span id="rScore"></span>%</p>
</div>

</div>

<div class="right">
<h3>Question Palette</h3>
<br>
<div class="palette" id="palette"></div>

<div class="links">
<a href="https://t.me/nursingsolution88" target="_blank">Telegram Channel</a>
<a href="https://whatsapp.com/channel/0029Vb60ICxBPzjUZDBd680p" target="_blank">WhatsApp Channel</a>
</div>
</div>

</div>

<script>

const API_URL =
"https://script.google.com/macros/s/AKfycby7NJhNamHWoVK3yPZrEOAk6JeEN5yTByzXnsYcIKQK7K2XViLIrgPSPGRmM17bMQY/exec";

let questions=[];
let current=0;
let answers={};

fetch(API_URL)
.then(res=>res.json())
.then(data=>{

questions=data.sort(()=>0.5-Math.random()).slice(0,30);

document.getElementById("totalNo").innerText=questions.length;

createPalette();
showQuestion();

})
.catch(err=>{
document.getElementById("questionText").innerHTML=
"Unable to load questions";
console.log(err);
});

function showQuestion(){

let q=questions[current];

document.getElementById("currentNo").innerText=current+1;

document.getElementById("questionText").innerHTML=
q.question;

let html="";

html+=`
<label class="option">
<input type="radio" name="opt"
value="1"
${answers[q.id]==1?"checked":""}
onclick="saveAnswer(1)">
${q.option1}
</label>`;

html+=`
<label class="option">
<input type="radio" name="opt"
value="2"
${answers[q.id]==2?"checked":""}
onclick="saveAnswer(2)">
${q.option2}
</label>`;

html+=`
<label class="option">
<input type="radio" name="opt"
value="3"
${answers[q.id]==3?"checked":""}
onclick="saveAnswer(3)">
${q.option3}
</label>`;

html+=`
<label class="option">
<input type="radio" name="opt"
value="4"
${answers[q.id]==4?"checked":""}
onclick="saveAnswer(4)">
${q.option4}
</label>`;

document.getElementById("options").innerHTML=html;

updateProgress();

}

function saveAnswer(val){

let q=questions[current];

answers[q.id]=val;

let btn=document.getElementById("p"+current);
if(btn) btn.classList.add("answered");

}

function nextQuestion(){

if(current<questions.length-1){
current++;
showQuestion();
}

}

function prevQuestion(){

if(current>0){
current--;
showQuestion();
}

}

function createPalette(){

let html="";

for(let i=0;i<30;i++){

html+=`
<button id="p${i}"
onclick="gotoQuestion(${i})">
${i+1}
</button>
`;

}

document.getElementById("palette").innerHTML=html;

}

function gotoQuestion(i){

current=i;
showQuestion();

}

function updateProgress(){

let p=((current+1)/questions.length)*100;

document.getElementById("progress").style.width=p+"%";

}

function submitTest(){

let correct=0;

questions.forEach(q=>{

if(Number(answers[q.id])===Number(q.answer)){
correct++;
}

});

let total=questions.length;

let wrong=total-correct;

let score=((correct/total)*100).toFixed(2);

document.getElementById("quizBox").style.display="none";
document.getElementById("resultBox").style.display="block";

document.getElementById("rTotal").innerText=total;
document.getElementById("rCorrect").innerText=correct;
document.getElementById("rWrong").innerText=wrong;
document.getElementById("rScore").innerText=score;

}

let time=60*60;

setInterval(()=>{

let m=Math.floor(time/60);
let s=time%60;

document.getElementById("timer").innerText=
String(m).padStart(2,'0')+":"+
String(s).padStart(2,'0');

if(time<=0){
submitTest();
}

time--;

},1000);

</script>

</body>
</html>
